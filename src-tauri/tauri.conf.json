{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atelier Vecteur",
  "version": "0.1.0",
  "identifier": "com.calib.svg-atelier",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atelier Vecteur",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://github.com https://objects.githubusercontent.com; object-src 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0NjIxRjRDQzNBMTdFMjkKUldRcGZxSERUQjlpVk41a1d3ZGUzSko5NEVTblBPV2pLM1JoTXNnU250S2paQURjQmZXWXNGRzMK",
      "endpoints": [
        "https://github.com/REMPLACE_PAR_TON_COMPTE/REMPLACE_PAR_TON_DEPOT/releases/latest/download/latest.json"
      ]
    }
  }
}
